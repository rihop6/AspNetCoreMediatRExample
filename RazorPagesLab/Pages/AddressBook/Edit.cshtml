@page
@model EditModel
@{
	ViewData["Title"] = "Edit Address Book Entry";
}

<style>
	.validation-summary-valid { display: none; }
</style>

<h1>Address Book Entry Details</h1>

<form asp-page="Edit"
	method="post">
	<span>@ViewData["Message"]</span>

	<div asp-validation-summary="All"
		class="validation-summary-errors">
		<span>Please correct the following errors:</span>
	</div>

	<div class="form-group">
		<span asp-for="EditAddressRequest.Id"></span>
		<input asp-for="EditAddressRequest.Id"
				type="hidden" />
	</div>
	<div class="form-group">
		<label asp-for="EditAddressRequest.Line1"></label>
		<input asp-for="EditAddressRequest.Line1"
				type="text"
				class="form-control"
				id="line1"
				placeholder="Line 1" />
	</div>
	<div class="form-group">
		<label asp-for="EditAddressRequest.Line2"></label>
		<input asp-for="EditAddressRequest.Line2"
				type="text"
				class="form-control"
				id="line2"
				placeholder="Line 2" />
	</div>
	<div class="form-group">
		<label asp-for="EditAddressRequest.City"></label>
		<input asp-for="EditAddressRequest.City"
				type="text"
				class="form-control"
				id="City"
				placeholder="City" />
	</div>
	<div class="form-group">
		<label asp-for="EditAddressRequest.State"></label>
		<input asp-for="EditAddressRequest.State"
				type="text"
				class="form-control"
				id="State"
				placeholder="State" />
	</div>
	<div class="form-group">
		<label asp-for="EditAddressRequest.PostalCode"></label>
		<input asp-for="EditAddressRequest.PostalCode"
				type="text"
				class="form-control"
				placeholder="Postal Code" />
	</div>
	<button type="submit"
			class="btn btn-primary">
		Update Address
	</button>
</form>